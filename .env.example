# ─── Cymek Environment Variables ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The root .env is consumed by all services. Each service reads only its own vars.

# ── LLM Provider ───────────────────────────────────────────────────────────────
# Default: Ollama (local). For production: set OPENAI_BASE_URL + OPENAI_API_KEY.
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Server ─────────────────────────────────────────────────────────────────────
# PORT=3001
# NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────────────
# Postgres 17 + pgvector. Created by `pnpm db:migrate`.
# DATABASE_URL=postgres://user:password@localhost:5432/cymek

# ── Encryption ──────────────────────────────────────────────────────────────────
# Master key for encrypting user API keys at rest.
# MUST be exactly 32 bytes for AES-256. Change in production.
# MASTER_ENCRYPTION_KEY=dev-master-key-32-bytes-long!!!

# ── Sidecar (Document Extraction) ──────────────────────────────────────────────
# Python FastAPI service running on port 8001 by default.
# SIDECAR_URL=http://localhost:8001

# ── Auth ───────────────────────────────────────────────────────────────────────
# JWT_SECRET=cymek-dev-jwt-secret-min-32-chars!!
# JWT_EXPIRES_IN=604800

# ── Logging ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=info

# ── OpenRouter (Production only) ───────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...
